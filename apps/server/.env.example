# Copy to .env and adjust. Never commit real secrets.

NODE_ENV=production

# Platform usually sets PORT (Railway, Render, Fly). Local default in server.js is 3000.
# PORT=3080

HOST=0.0.0.0

# SQLite path. Use a persistent volume path in production (e.g. /data/chat.db on Railway).
# DB_PATH=./data/chat.db

# Split frontend + API deploy: comma-separated exact origins (scheme + host + port).
# Example: CORS_ORIGIN=https://myapp.vercel.app,https://www.myapp.com
# Same-origin monolith (UI + API on one URL): leave unset — server allows Origin only when it matches the request Host.
# CORS_ORIGIN=
